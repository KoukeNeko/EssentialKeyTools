    <string name="onboarding_title">ONBOARDING</string>
    <string name="onboarding_step_intro">02 / 03 · Welcome</string>
    <string name="onboarding_intro_headline">MAKE THE ESSENTIAL KEY YOURS</string>
    <string name="onboarding_intro_body">Assign a different shortcut to each Essential Key gesture and run it without opening this app.</string>
    <string name="onboarding_intro_gestures_label">Four gestures</string>
    <string name="onboarding_intro_gestures_body">Single press · Double press · Triple press · Long press</string>
    <string name="onboarding_intro_setup_label">Finish setup in two steps</string>
    <string name="onboarding_intro_setup_body">1. Decide whether to enable Essential Key detection.&#10;2. Press the key once in Key Setup, then choose your shortcuts.</string>
    <string name="onboarding_continue">Continue</string>
    <string name="onboarding_permission_title">PERMISSION</string>
    <string name="onboarding_step_permission">03 / 03 · Accessibility service</string>
    <string name="onboarding_permission_headline">READ BEFORE YOU DECIDE</string>
    <string name="onboarding_permission_purpose">To let the Essential Key run shortcuts while this app is not open, Essential Key Tools needs Android’s accessibility service (AccessibilityService API).</string>
    <string name="onboarding_permission_data_label">Information the service receives</string>
    <string name="onboarding_permission_data_body">When enabled, the app receives which hardware key was pressed or released and when the event happened. It uses this information only to confirm that the key is the Essential Key, recognize a single, double, triple, or long press, and run the shortcut you selected.</string>
    <string name="onboarding_permission_actions_label">What the app can do</string>
    <string name="onboarding_permission_actions_body">The app uses accessibility to take a screenshot or lock the screen only if you assigned that action to a shortcut. It does not choose or run other actions on its own.</string>
    <string name="onboarding_permission_privacy_label">Storage and sharing</string>
    <string name="onboarding_permission_privacy_body">Key events are processed immediately on your device and are not stored, uploaded, or shared. Only the Essential Key identifier you confirm in Key Setup is stored on your device. The app does not read screen content, text fields, or text you type.</string>
    <string name="onboarding_permission_next_label">What happens after consent</string>
    <string name="onboarding_permission_next_body">Selecting “Agree: use accessibility service” opens Android Accessibility settings. Select “Essential Key detection,” review Android’s system warning, and turn on “Use Essential Key detection.” Returning, pressing Back, or selecting the decline option never enables the service.</string>
    <string name="onboarding_use_accessibility">Agree: use accessibility service</string>
    <string name="onboarding_continue_without_accessibility">Decline: don\'t use accessibility service</string>
    <string name="action_open_privacy_policy">View privacy policy</string>

    <!-- Accessibility enable flow -->
    <string name="a11y_disclosure_title">Before using the accessibility service</string>
    <string name="a11y_disclosure_body">To let the Essential Key run shortcuts while this app is not open, Essential Key Tools needs Android’s accessibility service (AccessibilityService API).\n\nWhen enabled, the app receives which hardware key was pressed or released and when the event happened. It uses this information only to confirm that the key is the Essential Key, recognize a single, double, triple, or long press, and run the shortcut you selected.\n\nKey events are processed immediately on your device and are not stored, uploaded, or shared. Only the Essential Key identifier you confirm in Key Setup is stored on your device. The app does not read screen content, text fields, or text you type.\n\nThe app uses accessibility to take a screenshot or lock the screen only if you assigned that action to a shortcut. It does not choose or run other actions on its own.</string>
    <string name="a11y_disclosure_question">Do you agree to Essential Key Tools using the accessibility service to detect the Essential Key and run the shortcuts you set?</string>
    <string name="a11y_disclosure_use_accessibility">Agree: use accessibility service</string>
    <string name="a11y_disclosure_continue_without_accessibility">Decline: don\'t use accessibility service</string>
    <string name="a11y_disclosure_back_declined">Treated as declined. The accessibility service was not enabled.</string>
    <string name="a11y_settings_body">Find "Essential Key detection" in the accessibility list and turn it on.</string>

