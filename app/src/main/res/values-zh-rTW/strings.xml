    <!-- Accessibility service -->
    <string name="accessibility_service_label">Essential Key 偵測</string>
    <string name="accessibility_service_description">在裝置上處理硬體按鍵事件，以辨識 Essential Key 手勢並執行你指定的動作。它不會讀取螢幕內容或輸入文字。</string>

